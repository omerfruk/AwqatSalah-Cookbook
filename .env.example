# ============================================================
#  AwqatSalah-Cookbook — Kimlik Bilgileri (TÜM DİLLER İÇİN TEK DOSYA)
# ============================================================
#
#  1) Bu dosyayı .env olarak kopyalayın:
#         cp .env.example .env
#  2) Aşağıya KENDİ bilgilerinizi girin.
#  3) Artık her dildeki örnek (go/, js/, python/ ...) aynı .env'i okur.
#     Bilgileri BİR KEZ girersiniz, tüm diller çalışır.
#
#  Hesap: https://awqatsalah.diyanet.gov.tr adresinden başvuru ile alınır.
#  NOT: .env dosyası .gitignore ile gizlidir, repoya gönderilmez.
# ------------------------------------------------------------

# --- ZORUNLU --- (örnek dosyadır; gerçek bilgiyi .env'e yazın, buraya DEĞİL)
AWQAT_EMAIL=
AWQAT_PASSWORD=

# --- OPSİYONEL (varsayılanlar yeterlidir) ---
AWQAT_BASE_URL=https://awqatsalah.diyanet.gov.tr

# Örnek baz konum: Türkiye / Isparta (isimden otomatik bulunur)
AWQAT_COUNTRY=Türkiye
AWQAT_STATE=Isparta

# --- OPSİYONEL ID OVERRIDE ---
# İsim aramasını atlamak ve günlük kotadan (path başına 5 istek) tasarruf
# etmek için ID'leri doğrudan girebilirsiniz. Boş bırakılırsa isimden bulunur.
# AWQAT_COUNTRY_ID=
# AWQAT_STATE_ID=
# AWQAT_CITY_ID=

# --- OPSİYONEL: TOKEN YENİDEN KULLANIMI ---
# Login günde 5 istekle sınırlıdır. Program, login sonrası token'ı otomatik
# .awqat-token.json (gizli) dosyasına kaydeder ve sonraki çalıştırmalarda
# GEÇERLİYSE yeniden login ATMAZ. Elle bir access token de verebilirsiniz:
# AWQAT_ACCESS_TOKEN=
# AWQAT_REFRESH_TOKEN=
